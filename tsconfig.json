{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "rootDir": "./src",
    "outDir": "./build",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "extends": "@tsconfig/node-lts/tsconfig.json",
  "include": ["./src"],
  "exclude": ["./src/**/*.spec.ts", "./src/**/*.test.ts"]
}

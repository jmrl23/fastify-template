{
  "version": "1.0.0",
  "name": "fastify-template",
  "repository": "https://github.com/jmrl23/fastify-template",
  "author": "Jomariel Gaitera <gaiterajomariel@gmail.com>",
  "license": "MIT",
  "main": "./build/main.js",
  "scripts": {
    "build": "tsc -p ./tsconfig.build.json",
    "test": "tsx node_modules/jest/bin/jest.js",
    "start": "node ./build/main.js",
    "start:dev": "nodemon",
    "start:prod": "dotenvx run --env NODE_ENV=production --ignore=MISSING_ENV_FILE -- node ./build/main.js",
    "format": "prettier --write \"./src/**/*.{ts,js}\"",
    "lint": "eslint"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.75.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/etag": "^6.1.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "detect-port": "^2.1.0",
    "env-var": "^7.5.0",
    "fastify": "^5.9.0",
    "fastify-plugin": "^5.1.0",
    "glob": "^13.0.6",
    "http-errors": "^2.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@jest/types": "^30.3.0",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@tsconfig/node-lts": "^24.0.0",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.4",
    "baseline-browser-mapping": "^2.10.40",
    "eslint": "^10.6.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jiti": "^2.7.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
